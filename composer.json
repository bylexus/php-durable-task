{
    "name": "bylexus/php-tr",
    "description": "Queued Task worker library for PHP backed by PostgreSQL.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "psr/container": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3",
        "vimeo/psalm": "^6.16"
    },
    "suggest": {
        "phpmailer/phpmailer": "If you want to run the examples with a mail component, install PHPMailer"
    },
    "autoload": {
        "psr-4": {
            "ByLexus\\TaskRunner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ByLexus\\TaskRunner\\Tests\\": "tests/",
            "ByLexus\\TaskRunner\\Examples\\": "examples/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "sort-packages": true
    }
}
